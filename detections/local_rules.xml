<!-- SSH BRUTE FORCE - T1110 -->
<group name="local,syslog,sshd,">

  <rule id="100001" level="5">
    <if_sid>5710,5716,5760</if_sid>
    <description>SSH: authentication failure from $(srcip)</description>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <rule id="100002" level="10" frequency="5" timeframe="120">
    <if_matched_sid>100001</if_matched_sid>
    <same_source_ip />
    <description>SSH BRUTE FORCE: 5+ failures from $(srcip) in 120s</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>authentication_failures,</group>
  </rule>

</group>

<!-- SUDO ABUSE - T1548.003 -->
<group name="local,syslog,sudo,">

  <rule id="100010" level="7">
    <if_sid>5401</if_sid>
    <description>SUDO: failed sudo attempt by $(srcuser)</description>
    <mitre>
      <id>T1548.003</id>
    </mitre>
  </rule>

  <rule id="100011" level="10" frequency="4" timeframe="120">
    <if_matched_sid>100010</if_matched_sid>
    <description>SUDO ABUSE: repeated failed sudo</description>
    <mitre>
      <id>T1548.003</id>
    </mitre>
  </rule>

</group>

<!-- USER CREATION - T1136 -->
<group name="local,syslog,adduser,">

  <rule id="100020" level="8">
    <if_sid>5902</if_sid>
    <description>ACCOUNT CREATED: new user added to system</description>
    <mitre>
      <id>T1136</id>
    </mitre>
  </rule>

</group>
